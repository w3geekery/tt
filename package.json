{
  "name": "tt",
  "version": "0.1.3",
  "description": "Local-first time tracker with MCP integration",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/core/server/index.ts",
    "dev:ui": "npm --prefix ui run start",
    "build": "tsc && npm --prefix ui run build",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate-from-neon.ts",
    "sync": "tsx scripts/sync-from-neon.ts",
    "sync:to-neon": "tsx scripts/sync-to-neon.ts",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "express": "^5.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.0.0",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
